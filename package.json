{
  "name": "@kraty/sdk",
  "version": "0.1.0",
  "license": "MIT",
  "description": "TypeScript SDK for the Kraty game-events platform. Targets the public /sdk/v1 surface: events, leaderboards, lobbies, grants, inventory, wallet, per-player auth.",
  "homepage": "https://kraty.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/PedroTrincheiras/kraty-sdk-typescript.git"
  },
  "bugs": "https://github.com/PedroTrincheiras/kraty-sdk-typescript/issues",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": ["kraty", "game-events", "leaderboard", "live-ops", "sdk"]
}
